{
    "name": "@onlook/brand-schema",
    "description": "Brand kit schema (identity tokens + strategy/voice) shared between Forge and Aegis",
    "version": "0.0.0",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/onlook-dev/onlook.git"
    },
    "type": "module",
    "main": "src/index.ts",
    "scripts": {
        "clean": "rm -rf node_modules",
        "lint": "eslint . --max-warnings 0",
        "format": "eslint --fix .",
        "typecheck": "tsc --noEmit",
        "test": "bun test"
    },
    "keywords": [
        "onlook",
        "brand-schema"
    ],
    "author": {
        "name": "Onlook",
        "email": "contact@onlook.com"
    },
