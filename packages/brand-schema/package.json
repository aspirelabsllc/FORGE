    "exports": {
        ".": "./src/index.ts",
        "./*": "./src/*/index.ts"
    },
    "devDependencies": {
        "@onlook/eslint": "*",
        "@onlook/typescript": "*",
        "@types/bun": "^1.2.4",
        "eslint": "^9.0.0",
        "typescript": "^5.5.4"
    },
    "dependencies": {
        "zod": "^4.1.3"
    }
}
